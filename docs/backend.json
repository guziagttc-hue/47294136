
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user identity and role information.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["BUYER", "SELLER", "ADMIN"] },
        "shopName": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "User profiles collection."
    }
  }
}
