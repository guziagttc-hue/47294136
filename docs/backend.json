
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user identity and role information.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["BUYER", "SELLER", "ADMIN"] },
        "shopName": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" }
      }
    },
    "Chat": {
      "title": "Chat",
      "description": "Represents a conversation between two users.",
      "type": "object",
      "properties": {
        "participants": { "type": "array", "items": { "type": "string" } },
        "participantNames": { "type": "object" },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Message": {
      "title": "Message",
      "description": "A single message within a chat.",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "senderId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "User profiles collection."
    },
    "/chats/{chatId}": {
      "schema": { "$ref": "#/backend/entities/Chat" },
      "description": "Collection of chat sessions."
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": { "$ref": "#/backend/entities/Message" },
      "description": "Sub-collection of messages within a chat."
    }
  }
}
